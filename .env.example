# ─────────────────────────────────────────────────────────────
# Project RoverSwarm — environment template
# Copy to .env and fill in the secrets:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# --- LLM ---
# TODO [Person 2]: required for GPT-4o orchestration, vision, and research agents
OPENAI_API_KEY=sk-...

# --- Redis (KV + Pub/Sub) ---
# Local default; point to Redis Cloud for shared rover access
REDIS_URL=redis://localhost:6379

# --- Weights & Biases Weave (observability) ---
# TODO [Person 1]: required for agent / vision / disagreement tracing
WANDB_API_KEY=...
WEAVE_PROJECT=roverswarm

# --- Execution mode ---
# true  = virtual rovers on a 2D grid (no hardware needed) -> runs out of the box
# false = real Lego rovers via the hardware command layer
SIMULATION_MODE=true

# --- Ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Frontend (Vite reads VITE_-prefixed vars) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# --- Hardware mode only (ignored when SIMULATION_MODE=true) ---
# TODO [Person 3]: hostnames / connection strings for each physical rover
ROVER1_HOST=
ROVER2_HOST=

# --- Gemma 2B edge model (local, per rover) ---
# TODO [Person 3]: path or endpoint for the local Gemma 2B model
GEMMA_MODEL_PATH=
