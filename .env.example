# ─────────────────────────────────────────────────────────────
# Project RoverSwarm — environment template
# Copy to .env and fill in the secrets:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# --- LLM ---
# TODO [Person 2]: required for GPT-4o orchestration and per-rover subagents
OPENAI_API_KEY=sk-...

# --- Redis (KV + Pub/Sub) ---
# Local default; point to Redis Cloud for shared rover access
REDIS_URL=redis://localhost:6379

# --- Weights & Biases Weave (observability) ---
# TODO [Person 1]: required for agent / vision / disagreement tracing
WANDB_API_KEY=...
WEAVE_PROJECT=SwarmSense

# --- Execution mode ---
# true  = virtual rovers on a 2D grid (no hardware needed) -> runs out of the box
# false = real Lego rovers via the hardware command layer
SIMULATION_MODE=true

# --- Rovers ---
# How many rovers/nodes to run (UI shows N1..Nn). Default 1 for single-robot testing.
ROVER_COUNT=1

# --- Live camera ---
# Option A: IP Webcam (HTTP snapshot). Accepts bare base URL or /video / /shot.jpg suffix.
#   Per-rover:  STREAM_URL_ROVER1=http://192.168.x.x:8080
#   Shared:     STREAM_URL=http://192.168.x.x:8080
# STREAM_URL=http://192.168.1.50:8080
#
# Option B: Local webcam / Continuity Camera (no network needed).
#   Plug iPhone into Mac → iPhone appears as device 1 (0 = built-in FaceTime camera).
#   Per-rover:  CAMERA_DEVICE_ROVER1=1
#   Shared:     CAMERA_DEVICE=1
# CAMERA_DEVICE=1

# --- Dev helpers ---
# Flush Redis on every backend startup (clean slate each restart).
FLUSH_ON_STARTUP=false
# Run a subagent analysis cycle on every new frame (set false to save vision cost).
AGENTS_AUTORUN=true

# --- Ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Frontend (Vite reads VITE_-prefixed vars) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# --- CopilotKit (AI chat sidebar) ---
# Copilot Cloud public key (get it at https://cloud.copilotkit.ai). When set,
# the frontend uses Copilot Cloud and no self-hosted runtime is needed.
VITE_COPILOT_PUBLIC_KEY=
# Set to "false" to hide the CopilotKit sidebar entirely.
VITE_COPILOT_ENABLED=true
# Self-hosted runtime URL (only used when VITE_COPILOT_PUBLIC_KEY is empty).
# VITE_COPILOT_RUNTIME_URL=/api/copilot

# --- Hardware mode only (ignored when SIMULATION_MODE=true) ---
# TODO [Person 3]: hostnames / connection strings for each physical rover
ROVER1_HOST=
ROVER2_HOST=

# --- Gemma 2B edge model (local, per rover) ---
# TODO [Person 3]: path or endpoint for the local Gemma 2B model
GEMMA_MODEL_PATH=
